# =====================================================================
# Ecclesia — modèle d'environnement PRODUCTION (Hostinger mutualisé)
# ---------------------------------------------------------------------
# Copiez ce fichier en `.env` SUR LE SERVEUR (jamais dans Git) puis
# renseignez les vraies valeurs. Générez la clé avec :
#   php artisan key:generate
# =====================================================================

APP_NAME=Ecclesia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin.votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# Force la génération d'URL en HTTPS derrière le proxy Hostinger.
ASSET_URL=https://admin.votre-domaine.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Base de données MySQL (hPanel → Bases de données MySQL) ---------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uXXXXXXXX_ecclesia
DB_USERNAME=uXXXXXXXX_ecclesia
DB_PASSWORD=change-me

# --- Sessions / cache / files ---------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- E-mails (codes de réinitialisation, etc.) ----------------------
# Renseignez un compte SMTP Hostinger (hPanel → Comptes e-mail).
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@votre-domaine.com
MAIL_PASSWORD=change-me
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="no-reply@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
